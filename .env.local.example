# ==============================================================================
# LUMIS EDTECH SAAS — Variables de Entorno
# ==============================================================================
# IMPORTANTE: Copia este archivo a `.env.local` y llena los valores.
# NUNCA incluyas tus claves secretas en el control de versiones.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 1. NEXT.JS CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
# URL base de tu aplicación (ej: http://localhost:3000 para dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Nota: No necesitamos NEXTAUTH_SECRET porque usamos Supabase Auth, no NextAuth.js.

# ──────────────────────────────────────────────────────────────────────────────
# 2. SUPABASE
# ──────────────────────────────────────────────────────────────────────────────
# Credenciales públicas para el cliente web/móvil
NEXT_PUBLIC_SUPABASE_URL=tu-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-supabase-anon-key

# Clave Service Role (Solo usar en servidor / para acciones administrativas)
# Esta clave se salta las políticas RLS. Úsala con precaución (ej. desde n8n o triggers).
SUPABASE_SERVICE_ROLE_KEY=tu-supabase-service-role-key

# ──────────────────────────────────────────────────────────────────────────────
# 3. WEBHOOKS EXTERNOS (N8N)
# ──────────────────────────────────────────────────────────────────────────────
# Token de seguridad para validar peticiones enviadas de Next.js a n8n
N8N_WEBHOOK_SECRET=tu-webhook-secret-token

# URLs para flujos de automatización de n8n (webhooks)
N8N_WEBHOOK_LEAD_URL=https://n8n.tudominio.com/webhook/new-lead
N8N_WEBHOOK_TOUR_URL=https://n8n.tudominio.com/webhook/new-tour
N8N_WEBHOOK_TOUR_CANCELLED_URL=https://n8n.tudominio.com/webhook/tour-cancelled
N8N_WEBHOOK_SOCIAL_URL=https://n8n.tudominio.com/webhook/social-publish

# Variables utilizadas dentro de los workflows de n8n
WHATSAPP_PHONE_ID=tu-whatsapp-phone-id
WHATSAPP_TOKEN=tu-whatsapp-token
GOOGLE_CALENDAR_TOKEN=tu-google-calendar-token
GOOGLE_CALENDAR_ID=primary
FB_PAGE_ID=tu-fb-page-id
FB_PAGE_TOKEN=tu-fb-page-token
IG_USER_ID=tu-ig-user-id
TIKTOK_ACCESS_TOKEN=tu-tiktok-access-token

# ──────────────────────────────────────────────────────────────────────────────
# 4. PAGOS Y FACTURACIÓN (STRIPE & MERCADO PAGO)
# ──────────────────────────────────────────────────────────────────────────────
# Stripe (Para el cobro de planes SaaS a los colegios)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_tu_stripe_public_key
STRIPE_SECRET_KEY=sk_test_tu_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_tu_stripe_webhook_secret

# Mercado Pago (Para cobro a padres en pasarela local MX)
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=TEST-tu-mp-public-key
MERCADO_PAGO_ACCESS_TOKEN=TEST-tu-mp-access-token

# ──────────────────────────────────────────────────────────────────────────────
# 5. WHATSAPP BUSINESS API (Integración CRM)
# ──────────────────────────────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=tu-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=tu-whatsapp-phone-id
WHATSAPP_BUSINESS_ACCOUNT_ID=tu-whatsapp-business-account-id

# ──────────────────────────────────────────────────────────────────────────────
# 6. GOOGLE CALENDAR API (Agendamiento de Tours)
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=tu-google-client-id
GOOGLE_CLIENT_SECRET=tu-google-client-secret

# ──────────────────────────────────────────────────────────────────────────────
# 7. META GRAPH API (Publicación en FB / IG)
# ──────────────────────────────────────────────────────────────────────────────
META_APP_ID=tu-meta-app-id
META_APP_SECRET=tu-meta-app-secret
META_SYSTEM_USER_ACCESS_TOKEN=tu-meta-system-user-access-token

# ──────────────────────────────────────────────────────────────────────────────
# 8. VERCEL DOMAINS API (Multi-tenant)
# ──────────────────────────────────────────────────────────────────────────────
# Token para automatizar el alta de dominios custom (colegio.edu.mx)
VERCEL_API_TOKEN=tu-vercel-api-token
VERCEL_PROJECT_ID=tu-vercel-project-id
VERCEL_TEAM_ID=tu-vercel-team-id # (Opcional, si aplicas)
